# Configuration
output_dir := "out"
efi_vars_tmp := "/tmp/bingo-vars.fd"
kernel_version := "6.12.81"
kernel_sha256 := "c2b09c3643946a7097c5371e1dcb123c66505ea30fafd0b0a22dc1d5f0228847"

# List available recipes
[default]
list:
    @just --list --unsorted

# Dependency checks
[private]
check-docker:
    @command -v docker >/dev/null 2>&1 || { echo "ERROR: docker is not installed." >&2; exit 1; }

[private]
check-qemu:
    @command -v qemu-system-aarch64 >/dev/null 2>&1 || { echo "ERROR: qemu-system-aarch64 is not installed." >&2; exit 1; }

[private]
check-lint:
    @command -v golangci-lint >/dev/null 2>&1 || { echo "ERROR: golangci-lint is not installed." >&2; exit 1; }

# Build the arm64 UEFI disk image: just build
[group('build')]
build: check-docker
    #!/usr/bin/env bash
    set -euo pipefail

    artifact="{{output_dir}}/bingo.arm64.img"

    mkdir -p {{output_dir}}
    docker build \
        --platform linux/arm64 \
        --target export-img \
        --output "type=local,dest={{output_dir}}" \
        --build-arg KERNEL_VERSION={{kernel_version}} \
        --build-arg KERNEL_SHA256={{kernel_sha256}} \
        .

    if [[ -f "${artifact}" ]]; then
        echo "SUCCESS: ${artifact} ($(du -h "${artifact}" | cut -f1))"
    else
        echo "ERROR: build failed, no artifact produced." >&2
        exit 1
    fi

# Build then boot the arm64 image in QEMU: just run
[group('run')]
run: check-qemu build
    #!/usr/bin/env bash
    set -euo pipefail

    artifact="{{output_dir}}/bingo.arm64.img"

    cp /opt/homebrew/share/qemu/edk2-arm-vars.fd {{efi_vars_tmp}}
    exec qemu-system-aarch64 \
        -machine virt -accel hvf -cpu host \
        -m 256 \
        -drive if=pflash,format=raw,readonly=on,file=/opt/homebrew/share/qemu/edk2-aarch64-code.fd \
        -drive if=pflash,format=raw,file={{efi_vars_tmp}} \
        -drive if=virtio,file="${artifact}",format=raw \
        -netdev user,id=net0,hostfwd=tcp::8080-:8080 \
        -device virtio-net-pci,netdev=net0 \
        -nographic

# Run linter on Go code
[group('dev')]
lint: check-lint
    cd src && GOOS=linux golangci-lint run --config .golangci.yml ./...

# Remove build outputs and Docker caches
[group('dev')]
[confirm("Delete all build artifacts and Docker caches?")]
clean: check-docker
    #!/usr/bin/env bash
    set -eu
    rm -rf {{output_dir}}
    docker image rm -f bingo-builder-arm64 >/dev/null 2>&1 || true
    docker buildx prune -f \
        --filter "type=exec.cachemount" \
        --filter "description~=bingo-"
